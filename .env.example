# ==============================================================================
# TORRENTING MODULE - ENVIRONMENT VARIABLES
# ==============================================================================
# Description: Module-specific environment defaults for spoke-torrenting
# Author: Matt Barham
# Created: 2026-02-13
# Modified: 2026-04-21
# Version: 1.0.1
# Host: Your Server
# ==============================================================================
# Type: Template
# Security Level: HIGH - Contains VPN API key and qBittorrent password defaults
# Component: module: torrenting
# ==============================================================================
# Note: This file provides module defaults. Hub base.env variables are merged
#       automatically by Spoke. Site-specific overrides go in modules.yml.
# ==============================================================================

#### IMAGES

GLUETUN_IMAGE=qmcgaw/gluetun:v3.41.1
QBITTORRENT_IMAGE=ghcr.io/hotio/qbittorrent:release-5.1.4
QSTICKY_IMAGE=ghcr.io/monstermuffin/qsticky:sha-98c834e
SLSKD_IMAGE=slskd/slskd:0.25.1

#### NETWORK

GLUETUN_IP=192.168.35.80
QSTICKY_IP=192.168.35.81
QBITTORRENT_IP=192.168.35.82

QBITTORRENT_WEB_UI_PORT=6611
GLUETUN_CONTROL_SERVER_PORT=6612
SLSKD_HTTP_PORT=5030
SLSKD_HTTPS_PORT=5031
SLSKD_LISTEN_PORT=50300

#### DATA PATHS

DL_DIR=/mnt/storage/data/downloads
MUSIC_DIR=/mnt/storage/media/Music

#### QBITTORRENT (plain text; secrets not supported)

QBITTORRENT_PASS=changeme

#### GLUETUN VPN (plain text; secrets not supported)

GLUETUN_API_KEY=changeme
